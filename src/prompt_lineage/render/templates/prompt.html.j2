{% extends "_base.html.j2" %}
{% block body %}

<p style="font-family:var(--mono);font-size:11px;color:var(--fg-muted);text-transform:uppercase;letter-spacing:0.06em;margin:0 0 12px">
  <a href="../index.html" style="color:inherit;text-decoration:none">&laquo; back to lineage</a>
</p>

<h2 style="margin:0 0 4px;font-family:var(--mono);font-size:18px">{{ prompt.id }}</h2>
<div style="font-family:var(--mono);font-size:12px;color:var(--fg-muted);margin-bottom:24px">
  {% if prompt.model_alias %}{{ prompt.model_alias }} &middot; {% endif %}
  {% if prompt.last_modified %}modified {{ prompt.last_modified }}{% endif %}
</div>

<dl class="detail-grid" style="padding:16px;border:1px solid var(--border);background:var(--bg-card);border-radius:6px">
  <dt>path</dt><dd>{{ prompt.path }}</dd>
  <dt>model</dt><dd>{{ prompt.model_alias or '-' }}</dd>
  {% if prompt.freshness %}
  <dt>status</dt><dd><span class="status status-{{ prompt.freshness.status or 'unevaluated' }}">{{ prompt.freshness.status or 'unevaluated' }}</span></dd>
  <dt>warn after</dt><dd>{{ prompt.freshness.warn_after or '-' }}</dd>
  <dt>error after</dt><dd>{{ prompt.freshness.error_after or '-' }}</dd>
  <dt>last evaluated</dt><dd>{{ prompt.freshness.last_evaluated or 'never' }}</dd>
  {% endif %}
  <dt>eval suites</dt>
  <dd>
    {% if prompt.evaluated_by %}
    <ul>{% for s in prompt.evaluated_by %}<li>{{ s }}</li>{% endfor %}</ul>
    {% else %}<em style="color:var(--status-warning)">none -- prompt has no eval coverage</em>{% endif %}
  </dd>
  <dt>contracts</dt>
  <dd>
    {% if prompt.enforced_by %}
    <ul>{% for c in prompt.enforced_by %}<li>{{ c }}</li>{% endfor %}</ul>
    {% else %}<em style="color:var(--status-warning)">none -- no runtime contract wraps this prompt</em>{% endif %}
  </dd>
</dl>

{% if source_excerpt %}
<h3 class="section-header">prompt source</h3>
<pre style="background:var(--bg-card);border:1px solid var(--border);border-radius:6px;padding:14px;overflow-x:auto;font-family:var(--mono);font-size:12px;color:var(--fg);white-space:pre-wrap">{{ source_excerpt }}</pre>
{% endif %}

{% endblock %}

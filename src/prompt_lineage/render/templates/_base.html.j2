<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title or "prompt-lineage" }}</title>
  <link rel="stylesheet" href="{{ root_prefix }}style.css">
</head>
<body>
  <div class="wrap">
    <header class="site">
      <h1><a href="{{ root_prefix }}index.html" style="color:inherit;text-decoration:none">prompt-lineage</a></h1>
      <div class="meta">
        built {{ generated_at_display }} &middot;
        {{ counts.prompts }} prompts &middot;
        {{ counts.suites }} suites &middot;
        {{ counts.contracts }} contracts
      </div>
    </header>

    {% block body %}{% endblock %}

    <footer class="site">
      <div>generated by prompt-lineage v{{ version }} &middot; schema {{ schema_version }}</div>
      <div><a href="https://github.com/uppulaharshith2-rgb/prompt-lineage">source</a></div>
    </footer>
  </div>

  {% block scripts %}{% endblock %}
</body>
</html>
